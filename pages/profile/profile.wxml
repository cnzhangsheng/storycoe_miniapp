<!--
  我的页面
-->

<view class="profile-page">
  <!-- 未登录状态 -->
  <view class="login-prompt" wx:if="{{!isLoggedIn}}">
    <view class="prompt-icon">👤</view>
    <text class="prompt-title">登录您的账户</text>
    <text class="prompt-desc">登录后可以管理个人信息</text>
    <view class="login-btn" bindtap="onLoginTap">微信登录</view>
  </view>

  <!-- 已登录状态 -->
  <block wx:if="{{isLoggedIn}}">
    <!-- 用户卡片 -->
    <view class="user-card card">
      <view class="user-avatar" bindtap="onAvatarTap">
        <image src="{{userInfo.avatar}}" mode="aspectFill" />
        <view class="avatar-edit">更换</view>
      </view>
      <view class="user-info">
        <view class="user-name" bindtap="onNameTap">
          <text>{{userInfo.name || 'Lily 小象'}}</text>
          <text class="edit-icon">✏️</text>
        </view>
        <view class="user-level">Lv.{{stats.level || 1}}</view>
      </view>
    </view>

    <!-- 统计数据 -->
    <view class="stats-section">
      <view class="stats-grid">
        <view class="stats-item">
          <text class="stats-icon">📚</text>
          <text class="stats-value">{{stats.books_read || 0}}</text>
          <text class="stats-label">已读绘本</text>
        </view>
        <view class="stats-item">
          <text class="stats-icon">⭐</text>
          <text class="stats-value">{{stats.stars || 0}}</text>
          <text class="stats-label">累计星星</text>
        </view>
        <view class="stats-item">
          <text class="stats-icon">🔥</text>
          <text class="stats-value">{{stats.streak || 0}}</text>
          <text class="stats-label">连续天数</text>
        </view>
      </view>
    </view>

    <!-- 功能菜单 -->
    <view class="menu-section">
      <view class="menu-item card">
        <text class="menu-label">帮助与反馈</text>
      </view>
      <view class="menu-item card" bindtap="onLogout">
        <text class="menu-label logout">退出登录</text>
      </view>
    </view>
  </block>
</view>