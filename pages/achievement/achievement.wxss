.achievement-page {
  padding: 16px;
}

.card {
  background-color: #FFFFFF;
  border-radius: 16px;
  padding: 16px;
  margin-bottom: 16px;
}

/* 统计卡片 */
.stats-grid {
  display: flex;
  justify-content: space-around;
}

.stat-item {
  text-align: center;
}

.stat-icon {
  font-size: 24px;
}

.stat-value {
  font-size: 20px;
  font-weight: 700;
  color: #4CAF50;
  margin-top: 6px;
}

.stat-label {
  font-size: 11px;
  color: #999999;
  margin-top: 4px;
}

/* 等级卡片 */
.level-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12px;
}

.level-title {
  font-size: 16px;
  font-weight: 700;
}

.level-badge {
  padding: 4px 12px;
  background-color: #FF7043;
  border-radius: 8px;
  color: #FFFFFF;
  font-weight: 700;
}

.level-progress {
  text-align: center;
}

.level-text {
  font-size: 12px;
  color: #666666;
  margin-top: 8px;
}

/* 成就列表 */
.section-title {
  font-size: 18px;
  font-weight: 700;
  margin-bottom: 16px;
}

.loading, .empty {
  text-align: center;
  padding: 40px;
  color: #999999;
}

.achievements-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
}

.achievement-item {
  width: calc(50% - 6px);
  padding: 16px;
  border-radius: 16px;
  text-align: center;
}

.achievement-item.unlocked {
  background-color: #FFFFFF;
  border: 2px solid #4CAF50;
}

.achievement-item.locked {
  background-color: #F5F5F5;
  opacity: 0.6;
}

.achievement-icon {
  font-size: 32px;
}

.achievement-name {
  font-size: 14px;
  font-weight: 700;
  color: #333333;
  margin-top: 8px;
}

.achievement-desc {
  font-size: 12px;
  color: #666666;
  margin-top: 4px;
}

.achievement-status {
  margin-top: 8px;
  font-size: 11px;
}

.achievement-item.unlocked .achievement-status {
  color: #4CAF50;
}

.achievement-item.locked .achievement-status {
  color: #999999;
}