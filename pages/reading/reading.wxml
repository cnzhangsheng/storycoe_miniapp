<!--
  阅读页面 - 严格参考 Flutter 应用设计

  布局结构：
  1. 顶部导航栏（返回按钮 + 标题 + 页码指示器 + 更多按钮）
  2. 图片区域（自适应高度，圆角边框）
  3. 句子列表区域（白色圆角卡片）
-->

<view class="reading-page">
  <!-- 顶部导航栏 -->
  <view class="top-bar">
    <!-- 返回按钮 -->
    <view class="back-btn" bindtap="onGoBack">
      <text class="back-icon">‹</text>
    </view>

    <!-- 绘本标题 -->
    <view class="title-area" wx:if="{{!editingTitle}}" bindtap="onEditTitle">
      <text class="book-title">{{book.title || '绘本朗读'}}</text>
      <text class="edit-hint" wx:if="{{canEdit}}">✏️</text>
    </view>
    <!-- 编辑模式下的标题输入框 -->
    <view class="title-edit-area" wx:if="{{editingTitle && canEdit}}">
      <input
        class="title-input"
        type="text"
        value="{{book.title || ''}}"
        placeholder="请输入绘本名称"
        focus="{{editingTitle}}"
        bindblur="onTitleBlur"
        bindconfirm="onTitleConfirm"
      />
    </view>

    <!-- 页码指示器 -->
    <view class="page-indicator">
      <text class="page-icon">📖</text>
      <text class="page-text">{{currentPageIndex + 1}}/{{(book.pages && book.pages.length) || 0}}</text>
    </view>

    <!-- 收藏状态指示（非作者） -->
    <view wx:if="{{!canEdit}}" class="shelf-indicator {{isInShelf ? 'active' : ''}}" bindtap="toggleShelf">
      <text class="shelf-icon">{{isInShelf ? '❤️' : '🤍'}}</text>
    </view>

    <!-- 更多按钮 -->
    <view class="more-btn" bindtap="onShowMore">
      <text class="more-icon">⋮</text>
    </view>
  </view>

  <!-- 主内容区域 -->
  <view class="main-content">
    <!-- 图片区域 -->
    <view class="image-section">
      <view class="image-container {{currentPage && currentPage.image_url ? '' : 'empty'}}" bindtap="onImageTap">
        <image
          wx:if="{{currentPage && currentPage.image_url}}"
          class="page-image"
          src="{{currentPage.image_url}}"
          mode="aspectFit"
        />
        <!-- 空图片占位 -->
        <view wx:else class="empty-image">
          <text class="empty-icon">🖼️</text>
          <text class="empty-title">暂无图片</text>
          <text class="empty-subtitle">该页面尚未上传图片</text>
        </view>
      </view>

      <!-- 左右翻页按钮 -->
      <view class="page-controls">
        <view class="prev-btn {{currentPageIndex <= 0 ? 'disabled' : ''}}" bindtap="onPrevPage">
          <text>‹</text>
        </view>
        <view class="next-btn {{currentPageIndex >= ((book.pages && book.pages.length) || 0) - 1 ? 'disabled' : ''}}" bindtap="onNextPage">
          <text>›</text>
        </view>
      </view>
    </view>

    <!-- 句子列表区域 -->
    <view class="sentences-card">
      <!-- 处理中提示 -->
      <view class="processing-tip" wx:if="{{isProcessing}}">
        <view class="processing-spinner"></view>
        <text class="processing-text">正在识别文字，请稍候...</text>
      </view>

      <!-- 滑动翻页提示 -->
      <view class="swipe-tip" wx:if="{{showSwipeTip && book.pages && book.pages.length > 1 && !isProcessing}}">
        <text class="swipe-icon">👆</text>
        <text class="swipe-text">左右滑动图片可翻页</text>
      </view>

      <!-- 句子列表头部 -->
      <view class="sentences-header">
        <!-- 整页朗读按钮 -->
        <view wx:if="{{sentences.length > 0}}" class="play-all-btn {{isPlayingAll ? 'active' : ''}}" bindtap="onPlayAll">
          <text class="play-all-icon">{{isPlayingAll ? '⏸' : '▶'}}</text>
        </view>

        <text class="header-title" wx:if="{{sentences.length > 0}}">朗读练习</text>

        <!-- 翻译切换按钮 -->
        <view class="translation-btn {{showTranslation ? 'active' : ''}}" bindtap="onToggleTranslation">
          <text class="trans-text">译</text>
        </view>

        <!-- 语速选择器（靠右对齐） -->
        <view class="speed-buttons">
          <view class="speed-item {{speedIndex === 0 ? 'active' : ''}}" bindtap="onSetSpeed" data-index="0">
            <text>慢</text>
          </view>
          <view class="speed-item {{speedIndex === 1 ? 'active' : ''}}" bindtap="onSetSpeed" data-index="1">
            <text>中</text>
          </view>
          <view class="speed-item {{speedIndex === 2 ? 'active' : ''}}" bindtap="onSetSpeed" data-index="2">
            <text>快</text>
          </view>
        </view>
      </view>

      <!-- 句子列表 -->
      <scroll-view
        class="sentences-scroll {{isDragMode ? 'no-scroll' : ''}}"
        scroll-y="{{!isDragMode}}"
        enable-back-to-top
        scroll-with-animation
      >
        <!-- 有句子时显示列表 -->
        <view wx:if="{{sentences.length > 0}}" class="sentences-list" id="sentencesList">
          <!-- 拖拽提示 -->
          <view wx:if="{{isDragMode}}" class="drag-tip">
            <text class="drag-tip-text">拖拽调整顺序，松手完成</text>
          </view>

          <!-- 句子列表项 -->
          <view
            wx:for="{{sentences}}"
            wx:key="id"
            class="sentence-row {{dragIndex !== -1 && index !== dragIndex ? (dragOverIndex > dragIndex && index > dragIndex && index <= dragOverIndex ? 'shift-up' : '') + (dragOverIndex < dragIndex && index < dragIndex && index >= dragOverIndex ? 'shift-down' : '') : ''}}"
            data-index="{{index}}"
          >
            <!-- 左滑操作区域（拖拽模式下隐藏） -->
            <view class="swipe-actions" wx:if="{{canEdit && !isDragMode}}">
              <view class="swipe-action edit" catchtap="onEditSentence" data-index="{{index}}">
                <text class="action-icon">✏️</text>
                <text class="action-text">编辑</text>
              </view>
              <view class="swipe-action delete" catchtap="onDeleteSentence" data-index="{{index}}">
                <text class="action-icon">🗑️</text>
                <text class="action-text">删除</text>
              </view>
            </view>

            <!-- 句子卡片 -->
            <view
              class="sentence-card-wrapper {{swipedIndex === index ? 'swiped' : ''}} {{isDragMode && dragIndex === index ? 'dragging' : ''}}"
              data-index="{{index}}"
              bindlongpress="onDragStart"
              bindtouchstart="onCardTouchStart"
              bindtouchmove="onCardTouchMove"
              bindtouchend="onCardTouchEnd"
            >
              <view class="sentence-card {{currentPlayingIndex === index ? 'active' : ''}} {{editingSentenceIndex === index ? 'editing' : ''}}">
                <!-- 序号 -->
                <view class="card-index {{currentPlayingIndex === index ? 'active' : ''}}">
                  <text>{{index + 1}}</text>
                </view>

                <!-- 内容区域：普通模式 -->
                <view class="card-content" wx:if="{{editingSentenceIndex !== index}}">
                  <view class="card-en-wrapper">
                    <text class="card-en {{currentPlayingIndex === index ? 'active' : ''}}">{{item.en || item.text}}</text>
                  </view>
                  <view wx:if="{{showTranslation && (item.zh || item.translation)}}" class="card-zh-wrapper">
                    <text class="card-zh">{{item.zh || item.translation}}</text>
                  </view>
                </view>

                <!-- 内容区域：编辑模式 -->
                <view class="card-edit-content" wx:if="{{editingSentenceIndex === index}}">
                  <input
                    class="sentence-input"
                    type="text"
                    value="{{editingSentenceValue}}"
                    placeholder="请输入英文句子"
                    focus="{{editingSentenceIndex === index}}"
                    data-index="{{index}}"
                    bindinput="onSentenceInputChange"
                    bindblur="onSentenceInputBlur"
                    bindconfirm="onSentenceInputConfirm"
                  />
                </view>

                <!-- 播放按钮（编辑时隐藏） -->
                <view
                  wx:if="{{editingSentenceIndex !== index}}"
                  class="card-play-btn {{currentPlayingIndex === index && isPlaying ? 'playing' : currentPlayingIndex === index && isPaused ? 'paused' : ''}}"
                  catchtap="onPlayBtnTap"
                  data-index="{{index}}"
                >
                  <text class="play-icon">{{currentPlayingIndex === index && isPlaying ? '⏸' : '▶'}}</text>
                </view>

                <!-- 编辑模式下的确认按钮 -->
                <view
                  wx:if="{{editingSentenceIndex === index}}"
                  class="card-confirm-btn"
                  catchtap="onSentenceEditConfirm"
                  data-index="{{index}}"
                >
                  <text class="confirm-icon">✓</text>
                </view>
              </view>
            </view>
          </view>

          <!-- 添加句子按钮 -->
          <view wx:if="{{canEdit && !isDragMode && !isAddingSentence}}" class="add-sentence-btn" bindtap="onAddSentence">
            <text class="add-icon">+</text>
            <text class="add-text">添加句子</text>
          </view>

          <!-- 添加句子输入框 -->
          <view wx:if="{{canEdit && !isDragMode && isAddingSentence}}" class="add-sentence-input-area">
            <view class="add-input-wrapper">
              <input
                class="add-sentence-input"
                type="text"
                value="{{newSentenceValue}}"
                placeholder="请输入英文句子"
                focus="{{isAddingSentence}}"
                bindinput="onNewSentenceInput"
                bindblur="onNewSentenceBlur"
                bindconfirm="onNewSentenceConfirm"
              />
            </view>
            <view class="add-confirm-btn" catchtap="onNewSentenceConfirmTap">
              <text class="confirm-icon">✓</text>
            </view>
            <view class="add-cancel-btn" catchtap="onNewSentenceCancel">
              <text class="cancel-icon">×</text>
            </view>
          </view>
        </view>

        <!-- 无句子时显示空状态 -->
        <view wx:else class="empty-sentences">
          <text class="empty-icon">💬</text>
          <text class="empty-text">当前页面暂无句子</text>
        </view>
      </scroll-view>
    </view>
  </view>

  <!-- 拖拽浮层（页面顶层，fixed定位） -->
  <view
    wx:if="{{isDragMode && dragIndex !== -1}}"
    class="drag-floating-card"
    style="top: {{dragFloatY}}px; left: 16px; right: 16px;"
  >
    <!-- 拖拽手柄 -->
    <view class="drag-handle-icon">
      <text>☰</text>
    </view>

    <!-- 序号 -->
    <view class="drag-index-badge">
      <text>{{dragOverIndex + 1}}</text>
    </view>

    <!-- 内容 -->
    <view class="drag-content">
      <text class="drag-en-text">{{dragSentenceText}}</text>
    </view>
  </view>
</view>