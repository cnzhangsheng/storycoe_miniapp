/**
 * 阅读页面样式 - 严格参考 Flutter 应用设计
 */

/* 页面整体 */
.reading-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #F5F5F5;
}

/* ========================================
   顶部导航栏
   ======================================== */
.top-bar {
  display: flex;
  align-items: center;
  padding: 12px 16px;
  background-color: #FFFFFF;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
}

.back-btn {
  width: 40px;
  height: 40px;
  background-color: #F5F5F5;
  border-radius: 12px;
  display: flex;
  justify-content: center;
  align-items: center;
}

.back-icon {
  font-size: 24px;
  color: #333333;
  font-weight: 600;
}

.title-area {
  display: flex;
  align-items: center;
  margin-left: 12px;
  flex: 1;
}

.book-title {
  font-size: 18px;
  font-weight: 800;
  color: #333333;
  max-width: 200px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.edit-hint {
  font-size: 14px;
  margin-left: 4px;
  opacity: 0.5;
}

.page-indicator {
  display: flex;
  align-items: center;
  padding: 6px 12px;
  background-color: rgba(76, 175, 80, 0.2);
  border-radius: 16px;
  margin-left: 8px;
}

.page-icon {
  font-size: 14px;
}

.page-text {
  font-size: 12px;
  font-weight: 700;
  color: #4CAF50;
  margin-left: 4px;
}

.shelf-indicator {
  width: 32px;
  height: 32px;
  background-color: #F5F5F5;
  border-radius: 10px;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-left: 8px;
}

.shelf-indicator.active {
  background-color: rgba(255, 112, 67, 0.2);
}

.shelf-icon {
  font-size: 16px;
}

.more-btn {
  width: 40px;
  height: 40px;
  background-color: #F5F5F5;
  border-radius: 12px;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-left: 8px;
}

.more-icon {
  font-size: 20px;
  color: #333333;
}

/* ========================================
   主内容区域
   ======================================== */
.main-content {
  display: flex;
  flex-direction: column;
  flex: 1;
  overflow: hidden;
}

/* ========================================
   图片区域
   ======================================== */
.image-section {
  position: relative;
  margin: 12px;
}

.image-container {
  border-radius: 16px;
  border: 3px solid #FFFFFF;
  box-shadow: 0 4px 16px rgba(0, 0, 0, 0.1);
  overflow: hidden;
  background-color: #E0E0E0;
  height: 200px;
}

.image-container.empty {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
}

.page-image {
  width: 100%;
  height: 100%;
}

.empty-image {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.empty-icon {
  font-size: 40px;
  opacity: 0.5;
}

.empty-title {
  font-size: 16px;
  font-weight: 600;
  color: #666666;
  opacity: 0.7;
  margin-top: 16px;
}

.empty-subtitle {
  font-size: 12px;
  color: #666666;
  opacity: 0.5;
  margin-top: 8px;
}

.page-controls {
  position: absolute;
  left: 0;
  right: 0;
  top: 50%;
  transform: translateY(-50%);
  display: flex;
  justify-content: space-between;
  padding: 0 8px;
  pointer-events: none;
}

.prev-btn, .next-btn {
  width: 36px;
  height: 36px;
  background-color: rgba(255, 255, 255, 0.8);
  border-radius: 18px;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 20px;
  color: #333333;
  pointer-events: auto;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
}

.prev-btn.disabled, .next-btn.disabled {
  opacity: 0.3;
}

/* ========================================
   句子列表区域
   ======================================== */
.sentences-card {
  flex: 1;
  display: flex;
  flex-direction: column;
  background-color: #FFFFFF;
  border-radius: 24px 24px 0 0;
  box-shadow: 0 -4px 16px rgba(0, 0, 0, 0.05);
  overflow: hidden;
}

.processing-tip {
  margin: 12px 16px 0;
  padding: 12px 16px;
  background-color: rgba(255, 152, 0, 0.1);
  border-radius: 16px;
  display: flex;
  align-items: center;
}

.processing-spinner {
  width: 20px;
  height: 20px;
  border: 2px solid rgba(255, 152, 0, 0.3);
  border-top-color: #FF9800;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.processing-text {
  font-size: 14px;
  color: #FF9800;
  font-weight: 600;
  margin-left: 12px;
}

.swipe-tip {
  margin: 8px 16px 0;
  padding: 6px 12px;
  background-color: rgba(76, 175, 80, 0.1);
  border-radius: 12px;
  display: flex;
  align-items: center;
}

.swipe-icon {
  font-size: 14px;
}

.swipe-text {
  font-size: 11px;
  color: #4CAF50;
  font-weight: 500;
  margin-left: 6px;
}

/* ========================================
   句子列表头部
   ======================================== */
.sentences-header {
  display: flex;
  align-items: center;
  padding: 8px 12px 6px;
  border-bottom: 1px solid rgba(0, 0, 0, 0.05);
}

.play-all-btn {
  width: 32px;
  height: 32px;
  background-color: #4CAF50;
  border-radius: 10px;
  display: flex;
  justify-content: center;
  align-items: center;
  box-shadow: 0 2px 6px rgba(76, 175, 80, 0.5);
}

.play-all-btn.active {
  background-color: #FF7043;
}

.play-all-icon {
  font-size: 12px;
  color: #FFFFFF;
}

.header-title {
  font-size: 15px;
  font-weight: 800;
  color: #333333;
  margin-left: 8px;
}

.translation-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 4px 12px;
  background-color: #E0E0E0;
  border-radius: 8px;
  margin-left: 8px;
}

.translation-btn.active {
  background-color: #FF7043;
}

.trans-text {
  font-size: 12px;
  font-weight: 600;
  color: #666666;
}

.translation-btn.active .trans-text {
  color: #FFFFFF;
}

/* 发音切换 */
.accent-buttons {
  display: flex;
  gap: 6px;
  margin-left: auto;
  margin-right: 8px;
}

.accent-item {
  width: 32px;
  height: 32px;
  background-color: #F5F5F5;
  border-radius: 8px;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 16px;
}

.accent-item.active {
  background-color: #4CAF50;
}

/* 语速选择器靠右对齐 */
.speed-buttons {
  display: flex;
  gap: 6px;
  margin-left: auto;
}

.speed-item {
  padding: 4px 12px;
  background-color: #F5F5F5;
  border-radius: 8px;
  font-size: 12px;
  font-weight: 500;
  color: #666666;
}

.speed-item.active {
  background-color: #4CAF50;
  color: #FFFFFF;
}

/* ========================================
   句子列表滚动区域
   ======================================== */
.sentences-scroll {
  flex: 1;
  overflow: hidden;
}

.sentences-scroll.no-scroll {
  overflow: hidden;
}

.sentences-list {
  padding: 8px 16px;
}

/* ========================================
   拖拽提示
   ======================================== */
.drag-tip {
  padding: 10px 16px;
  background-color: rgba(76, 175, 80, 0.15);
  border-radius: 12px;
  margin-bottom: 12px;
}

.drag-tip-text {
  font-size: 14px;
  font-weight: 600;
  color: #4CAF50;
}

/* ========================================
   句子行（支持避让动画）
   ======================================== */
.sentence-row {
  position: relative;
  margin-bottom: 12px;
  transition: transform 0.25s ease, opacity 0.15s ease;
}

/* 向上避让 */
.sentence-row.shift-up {
  transform: translateY(-80px);
}

/* 向下避让 */
.sentence-row.shift-down {
  transform: translateY(80px);
}

/* ========================================
   左滑操作按钮
   ======================================== */
.swipe-actions {
  position: absolute;
  right: 0;
  top: 0;
  height: 100%;
  display: flex;
  z-index: 1;
}

.swipe-action {
  width: 70px;
  height: 100%;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
}

.swipe-action.edit {
  background-color: #4CAF50;
}

.swipe-action.delete {
  background-color: #F44336;
}

.action-icon {
  font-size: 18px;
}

.action-text {
  font-size: 12px;
  color: #FFFFFF;
  font-weight: 600;
  margin-top: 4px;
}

/* ========================================
   句子卡片包装器
   ======================================== */
.sentence-card-wrapper {
  position: relative;
  z-index: 2;
  background-color: #FFFFFF;
  transition: transform 0.25s ease, opacity 0.15s ease, box-shadow 0.2s ease;
}

/* 左滑状态 */
.sentence-card-wrapper.swiped {
  transform: translateX(-140px);
}

/* 拖拽状态（原卡片上浮变色） */
.sentence-card-wrapper.dragging {
  opacity: 0.3;
  transform: translateY(-6px);
}

/* ========================================
   句子卡片
   ======================================== */
.sentence-card {
  display: flex;
  align-items: flex-start;
  padding: 16px;
  background-color: #FFFFFF;
  border-radius: 16px;
  border: 2px solid transparent;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
  transition: all 0.2s ease;
}

.sentence-card.active {
  background-color: rgba(76, 175, 80, 0.15);
  border-color: #4CAF50;
  box-shadow: 0 8px 16px rgba(76, 175, 80, 0.3);
}

/* 拖拽状态下的原卡片样式 */
.sentence-card-wrapper.dragging .sentence-card {
  border-color: rgba(76, 175, 80, 0.5);
  background-color: rgba(76, 175, 80, 0.08);
}

/* ========================================
   卡片序号
   ======================================== */
.card-index {
  width: 28px;
  height: 28px;
  background-color: #E0E0E0;
  border-radius: 8px;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 12px;
  font-weight: 800;
  color: #666666;
}

.card-index.active {
  background-color: #FF7043;
  color: #FFFFFF;
}

/* ========================================
   卡片内容
   ======================================== */
.card-content {
  flex: 1;
  margin-left: 12px;
  display: flex;
  flex-direction: column;
}

.card-en-wrapper {
  display: block;
}

.card-en {
  font-size: 15px;
  font-weight: 600;
  color: #333333;
  opacity: 0.85;
  line-height: 1.5;
  display: block;
}

.card-en.active {
  font-size: 17px;
  font-weight: 700;
  opacity: 1;
}

.card-zh-wrapper {
  display: block;
  margin-top: 8px;
}

.card-zh {
  font-size: 13px;
  font-weight: 500;
  color: #666666;
  opacity: 0.7;
  line-height: 1.4;
  display: block;
}

.sentence-card.active .card-zh {
  color: #4CAF50;
  opacity: 0.9;
}

/* 翻译按钮 */
.translate-btn {
  display: inline-flex;
  align-items: center;
  padding: 4px 10px;
  background-color: rgba(33, 150, 243, 0.15);
  border-radius: 8px;
  gap: 4px;
}

.translate-btn.translating {
  background-color: rgba(255, 152, 0, 0.15);
}

.translate-icon {
  font-size: 12px;
}

.translate-text {
  font-size: 12px;
  font-weight: 600;
  color: #2196F3;
}

.translate-btn.translating .translate-text {
  color: #FF9800;
}

/* ========================================
   播放按钮
   ======================================== */
.card-right-area {
  display: flex;
  align-items: center;
  margin-left: 12px;
}

.card-play-btn {
  width: 44px;
  height: 44px;
  background-color: #4CAF50;
  border-radius: 14px;
  display: flex;
  justify-content: center;
  align-items: center;
  box-shadow: 0 3px 8px rgba(76, 175, 80, 0.3);
}

.card-play-btn.playing {
  background-color: #FF7043;
  box-shadow: 0 3px 8px rgba(255, 112, 67, 0.3);
}

.card-play-btn.paused {
  background-color: #2196F3;
}

.play-icon {
  font-size: 16px;
  color: #FFFFFF;
}

/* ========================================
   状态提示
   ======================================== */
.card-status-tip {
  display: flex;
  align-items: center;
  padding: 8px 12px;
  border-radius: 12px;
  gap: 6px;
}

.card-status-tip.generating {
  background-color: rgba(255, 152, 0, 0.15);
}

.card-status-tip.pending {
  background-color: rgba(158, 158, 158, 0.15);
}

.card-status-tip.error {
  background-color: rgba(244, 67, 54, 0.15);
}

.status-icon {
  font-size: 14px;
}

.status-text {
  font-size: 12px;
  font-weight: 600;
}

.card-status-tip.generating .status-text {
  color: #FF9800;
}

.card-status-tip.pending .status-text {
  color: #9E9E9E;
}

.card-status-tip.error .status-text {
  color: #F44336;
}

/* ========================================
   添加句子按钮
   ======================================== */
.add-sentence-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16px;
  background-color: rgba(76, 175, 80, 0.1);
  border-radius: 16px;
  margin-top: 12px;
}

.add-icon {
  font-size: 20px;
  color: #4CAF50;
  margin-right: 8px;
}

.add-text {
  font-size: 14px;
  font-weight: 600;
  color: #4CAF50;
}

/* ========================================
   空句子状态
   ======================================== */
.empty-sentences {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60px 20px;
}

.empty-icon {
  font-size: 48px;
  opacity: 0.3;
}

.empty-text {
  font-size: 14px;
  color: #666666;
  opacity: 0.5;
  margin-top: 16px;
}

/* ========================================
   拖拽浮层（跟随手指）
   ======================================== */
.drag-floating-card {
  position: fixed;
  height: 80px;
  background-color: #FFFFFF;
  border-radius: 16px;
  border: 2px solid #4CAF50;
  display: flex;
  align-items: center;
  padding: 16px 20px;
  z-index: 999;
  pointer-events: none;
  /* 放大和阴影 */
  transform: scale(1.05);
  box-shadow: 0 16px 40px rgba(76, 175, 80, 0.5);
}

.drag-handle-icon {
  width: 28px;
  height: 28px;
  background-color: #4CAF50;
  border-radius: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16px;
  color: #FFFFFF;
  margin-right: 12px;
}

.drag-index-badge {
  width: 28px;
  height: 28px;
  background-color: #4CAF50;
  border-radius: 8px;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 12px;
  font-weight: 800;
  color: #FFFFFF;
  margin-right: 12px;
}

.drag-content {
  flex: 1;
  overflow: hidden;
}

.drag-en-text {
  font-size: 15px;
  font-weight: 600;
  color: #333333;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* ========================================
   标题行内编辑
   ======================================== */
.title-edit-area {
  display: flex;
  align-items: center;
  margin-left: 12px;
  flex: 1;
}

.title-input {
  font-size: 18px;
  font-weight: 800;
  color: #333333;
  background-color: #F5F5F5;
  border-radius: 8px;
  padding: 8px 12px;
  width: 100%;
  max-width: 200px;
}

/* ========================================
   句子行内编辑
   ======================================== */
.sentence-card.editing {
  background-color: rgba(255, 152, 0, 0.1);
  border-color: #FF9800;
}

.card-edit-content {
  flex: 1;
  margin-left: 12px;
}

.sentence-input {
  font-size: 15px;
  font-weight: 600;
  color: #333333;
  background-color: #FFFFFF;
  border-radius: 8px;
  padding: 8px 12px;
  width: 100%;
  border: 1px solid #FF9800;
}

.card-confirm-btn {
  width: 44px;
  height: 44px;
  background-color: #4CAF50;
  border-radius: 14px;
  display: flex;
  justify-content: center;
  align-items: center;
  box-shadow: 0 3px 8px rgba(76, 175, 80, 0.3);
  margin-left: 12px;
}

.confirm-icon {
  font-size: 18px;
  color: #FFFFFF;
  font-weight: bold;
}

/* ========================================
   添加句子输入区域
   ======================================== */
.add-sentence-input-area {
  display: flex;
  align-items: center;
  padding: 16px;
  background-color: rgba(255, 152, 0, 0.1);
  border-radius: 16px;
  margin-top: 12px;
  border: 2px solid #FF9800;
}

.add-input-wrapper {
  flex: 1;
}

.add-sentence-input {
  font-size: 15px;
  font-weight: 600;
  color: #333333;
  background-color: #FFFFFF;
  border-radius: 8px;
  padding: 10px 12px;
  width: 100%;
  border: 1px solid #FF9800;
}

.add-confirm-btn {
  width: 40px;
  height: 40px;
  background-color: #4CAF50;
  border-radius: 12px;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-left: 12px;
}

.add-cancel-btn {
  width: 40px;
  height: 40px;
  background-color: #F44336;
  border-radius: 12px;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-left: 8px;
}

.add-confirm-btn .confirm-icon,
.add-cancel-btn .cancel-icon {
  font-size: 16px;
  color: #FFFFFF;
  font-weight: bold;
}