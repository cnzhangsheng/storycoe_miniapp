/**
 * 阅读页面样式 - 严格参考 Flutter 应用设计
 */

/* 页面整体 */
.reading-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #F5F5F5;
}

/* ========================================
   顶部导航栏
   ======================================== */
.top-bar {
  display: flex;
  align-items: center;
  padding: 12px 16px;
  background-color: #FFFFFF;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
}

.back-btn {
  width: 40px;
  height: 40px;
  background-color: #F5F5F5;
  border-radius: 12px;
  display: flex;
  justify-content: center;
  align-items: center;
}

.back-icon {
  font-size: 24px;
  color: #333333;
  font-weight: 600;
}

.title-area {
  display: flex;
  align-items: center;
  margin-left: 12px;
  flex: 1;
}

.book-title {
  font-size: 18px;
  font-weight: 800;
  color: #333333;
  max-width: 200px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.edit-hint {
  font-size: 14px;
  margin-left: 4px;
  opacity: 0.5;
}

.page-indicator {
  display: flex;
  align-items: center;
  padding: 6px 12px;
  background-color: rgba(76, 175, 80, 0.2);
  border-radius: 16px;
  margin-left: 8px;
}

.page-icon {
  font-size: 14px;
}

.page-text {
  font-size: 12px;
  font-weight: 700;
  color: #4CAF50;
  margin-left: 4px;
}

/* 收藏状态指示 */
.shelf-indicator {
  width: 32px;
  height: 32px;
  background-color: #F5F5F5;
  border-radius: 10px;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-left: 8px;
}

.shelf-indicator.active {
  background-color: rgba(255, 112, 67, 0.2);
}

.shelf-icon {
  font-size: 16px;
}

.more-btn {
  width: 40px;
  height: 40px;
  background-color: #F5F5F5;
  border-radius: 12px;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-left: 8px;
}

.more-icon {
  font-size: 20px;
  color: #333333;
}

/* ========================================
   主内容区域
   ======================================== */
.main-content {
  display: flex;
  flex-direction: column;
  flex: 1;
  overflow: hidden;
}

/* ========================================
   图片区域
   ======================================== */
.image-section {
  position: relative;
  margin: 12px;
}

.image-container {
  border-radius: 16px;
  border: 3px solid #FFFFFF;
  box-shadow: 0 4px 16px rgba(0, 0, 0, 0.1);
  overflow: hidden;
  background-color: #E0E0E0;
  height: 200px; /* 默认高度，可根据图片比例自适应 */
}

.image-container.empty {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  background-color: #E0E0E0;
}

.page-image {
  width: 100%;
  height: 100%;
}

.empty-image {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.empty-icon {
  font-size: 40px;
  opacity: 0.5;
}

.empty-title {
  font-size: 16px;
  font-weight: 600;
  color: #666666;
  opacity: 0.7;
  margin-top: 16px;
}

.empty-subtitle {
  font-size: 12px;
  color: #666666;
  opacity: 0.5;
  margin-top: 8px;
}

/* 翻页按钮 */
.page-controls {
  position: absolute;
  left: 0;
  right: 0;
  top: 50%;
  transform: translateY(-50%);
  display: flex;
  justify-content: space-between;
  padding: 0 8px;
  pointer-events: none; /* 容器不阻挡点击 */
}

.prev-btn, .next-btn {
  width: 36px;
  height: 36px;
  background-color: rgba(255, 255, 255, 0.8);
  border-radius: 18px;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 20px;
  color: #333333;
  pointer-events: auto; /* 按钮可点击 */
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
}

.prev-btn.disabled, .next-btn.disabled {
  opacity: 0.3;
}

/* ========================================
   句子列表区域
   ======================================== */
.sentences-card {
  flex: 1;
  display: flex;
  flex-direction: column;
  background-color: #FFFFFF;
  border-radius: 24px 24px 0 0;
  box-shadow: 0 -4px 16px rgba(0, 0, 0, 0.05);
  overflow: hidden;
}

/* 处理中提示 */
.processing-tip {
  margin: 12px 16px 0;
  padding: 12px 16px;
  background-color: rgba(255, 152, 0, 0.1);
  border-radius: 16px;
  display: flex;
  align-items: center;
}

.processing-spinner {
  width: 20px;
  height: 20px;
  border: 2px solid rgba(255, 152, 0, 0.3);
  border-top-color: #FF9800;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.processing-text {
  font-size: 14px;
  color: #FF9800;
  font-weight: 600;
  margin-left: 12px;
}

/* 滑动翻页提示 */
.swipe-tip {
  margin: 8px 16px 0;
  padding: 6px 12px;
  background-color: rgba(76, 175, 80, 0.1);
  border-radius: 12px;
  display: flex;
  align-items: center;
}

.swipe-icon {
  font-size: 14px;
}

.swipe-text {
  font-size: 11px;
  color: #4CAF50;
  font-weight: 500;
  margin-left: 6px;
}

/* ========================================
   句子列表头部
   ======================================== */
.sentences-header {
  display: flex;
  align-items: center;
  padding: 8px 12px 6px;
  border-bottom: 1px solid rgba(0, 0, 0, 0.05);
}

.play-all-btn {
  width: 32px;
  height: 32px;
  background-color: #4CAF50;
  border-radius: 10px;
  display: flex;
  justify-content: center;
  align-items: center;
  box-shadow: 0 2px 6px rgba(76, 175, 80, 0.5);
}

.play-all-btn.active {
  background-color: #FF7043;
  box-shadow: none;
}

.play-all-icon {
  font-size: 12px;
  color: #FFFFFF;
}

.header-title {
  font-size: 15px;
  font-weight: 800;
  color: #333333;
  margin-left: 8px;
}

.translation-btn {
  display: flex;
  align-items: center;
  padding: 4px 8px;
  background-color: #E0E0E0;
  border-radius: 8px;
  margin-left: 8px;
}

.translation-btn.active {
  background-color: #FF7043;
}

.trans-icon {
  font-size: 12px;
}

.trans-text {
  font-size: 10px;
  font-weight: 600;
  color: #666666;
  margin-left: 3px;
}

.translation-btn.active .trans-text {
  color: #FFFFFF;
}

/* 语速选择器（平铺按钮） */
.speed-buttons {
  display: flex;
  gap: 6px;
  margin-left: 12px;
}

.speed-item {
  padding: 4px 10px;
  background-color: #F5F5F5;
  border-radius: 8px;
  font-size: 11px;
  font-weight: 500;
  color: #666666;
}

.speed-item.active {
  background-color: #4CAF50;
  color: #FFFFFF;
}

/* ========================================
   句子列表滚动区域
   ======================================== */
.sentences-scroll {
  flex: 1;
  overflow: hidden;
}

.sentences-list {
  padding: 8px 16px;
}

/* ========================================
   单个句子项
   ======================================== */
.sentence-item {
  display: flex;
  align-items: flex-start;
  padding: 16px;
  margin-bottom: 12px;
  background-color: #FFFFFF;
  border-radius: 16px;
  border: 2px solid transparent;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
  transition: all 0.2s;
}

.sentence-item.active {
  background-color: rgba(76, 175, 80, 0.15);
  border-color: #4CAF50;
  box-shadow: 0 8px 16px rgba(76, 175, 80, 0.3);
}

/* 序号徽章 */
.index-badge {
  width: 28px;
  height: 28px;
  background-color: #E0E0E0;
  border-radius: 8px;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 12px;
  font-weight: 800;
  color: #666666;
}

.index-badge.active {
  background-color: #FF7043;
  color: #FFFFFF;
}

/* 句子内容 */
.sentence-content {
  flex: 1;
  margin-left: 12px;
}

.sentence-en {
  font-size: 15px;
  font-weight: 600;
  color: #333333;
  opacity: 0.85;
  line-height: 1.5;
}

.sentence-en.active {
  font-size: 17px;
  font-weight: 700;
  color: #333333;
  opacity: 1;
}

.sentence-zh {
  font-size: 13px;
  font-weight: 500;
  color: #666666;
  opacity: 0.7;
  line-height: 1.4;
  margin-top: 6px;
}

.sentence-item.active .sentence-zh {
  font-size: 14px;
  color: #4CAF50;
  opacity: 0.9;
}

/* 播放按钮 */
.play-btn {
  width: 44px;
  height: 44px;
  background-color: #4CAF50;
  border-radius: 14px;
  display: flex;
  justify-content: center;
  align-items: center;
  box-shadow: 0 3px 8px rgba(76, 175, 80, 0.3);
  margin-left: 12px;
}

.play-btn.playing {
  background-color: #FF7043;
  box-shadow: 0 3px 8px rgba(255, 112, 67, 0.3);
}

.play-btn.paused {
  background-color: #2196F3;
}

.play-icon {
  font-size: 16px;
  color: #FFFFFF;
}

/* 编辑操作按钮 */
.edit-actions {
  display: flex;
  flex-direction: column;
  gap: 4px;
  margin-left: 8px;
}

.edit-btn, .delete-btn {
  width: 28px;
  height: 28px;
  border-radius: 8px;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 12px;
}

.edit-btn {
  background-color: rgba(76, 175, 80, 0.2);
}

.delete-btn {
  background-color: rgba(244, 67, 54, 0.2);
}

/* ========================================
   添加句子按钮
   ======================================== */
.add-sentence-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16px;
  background-color: rgba(76, 175, 80, 0.1);
  border-radius: 16px;
  margin-top: 12px;
}

.add-icon {
  font-size: 20px;
  color: #4CAF50;
  margin-right: 8px;
}

.add-text {
  font-size: 14px;
  font-weight: 600;
  color: #4CAF50;
}

/* ========================================
   空句子状态
   ======================================== */
.empty-sentences {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60px 20px;
}

.empty-icon {
  font-size: 48px;
  opacity: 0.3;
}

.empty-text {
  font-size: 14px;
  color: #666666;
  opacity: 0.5;
  margin-top: 16px;
}