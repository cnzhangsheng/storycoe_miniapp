<!--
  绘本卡片组件
-->

<view class="book-card {{mode}}" bindtap="onTap">
  <!-- 封面图片 -->
  <view class="book-cover">
    <image src="{{book.cover_image || defaultCover}}" mode="aspectFill" lazy-load />
  </view>

  <!-- 基本信息 -->
  <view class="book-info">
    <text class="book-title">{{book.title}}</text>

    <!-- 作者信息 -->
    <text class="book-author" wx:if="{{showAuthor && book.author_name}}">{{book.author_name}}</text>

    <!-- 统计信息 -->
    <view class="book-stats" wx:if="{{showStats}}">
      <text class="stat-item">👁 {{book.view_count || 0}}</text>
      <text class="stat-item">❤️ {{book.like_count || 0}}</text>
    </view>

    <!-- 级别标签 -->
    <view class="level-tag" wx:if="{{book.level}}">
      <text>Lv.{{book.level}}</text>
    </view>
  </view>

  <!-- 喜欢按钮 -->
  <view class="like-btn {{book.is_liked ? 'liked' : ''}}" wx:if="{{showStats}}" catchtap="onLikeTap">
    <text>{{book.is_liked ? '❤️' : '🤍'}}</text>
  </view>
</view>